    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.0.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.62.0",
